{
  "name": "still",
  "version": "0.1.0",
  "private": true,
  "description": "Still — a photo mood app",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:mobile": "yarn workspace @still/mobile start",
    "dev:backend": "yarn workspace @still/backend dev",
    "build": "yarn workspaces run build",
    "generate": "yarn generate:proto",
    "generate:proto": "./scripts/generate-proto.sh",
    "lint": "yarn workspaces run lint",
    "test": "yarn workspaces run test",
    "migrate": "./scripts/migrate.sh"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
