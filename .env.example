# Combined environment template for reference.
# `make env` copies the per-app templates from apps/backend/.env.example and apps/mobile/.env.example.

# Backend
APP_ENV=dev
PORT=8080
DATABASE_URL=postgres://localhost:5432/still?sslmode=disable

# AI
OPENAI_API_KEY=sk-...

# S3 / S3-compatible storage (dev: MinIO, prod: AWS S3 or Cloudflare R2)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=still-uploads
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin

# CORS
CORS_ALLOWED_ORIGINS=*

# Auth (Clerk) — https://dashboard.clerk.com
CLERK_SECRET_KEY=sk_test_...
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...

# Observability (Sentry) — optional
SENTRY_DSN=https://...@sentry.io/...

# OpenTelemetry — optional
OTEL_SERVICE_NAME=still-backend
OTEL_EXPORTER_OTLP_ENDPOINT=

# Mobile
EXPO_PUBLIC_API_BASE_URL=http://localhost:8080
