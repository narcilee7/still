# Environment
APP_ENV=dev
PORT=8080

# Database
DATABASE_URL=postgres://localhost:5432/still?sslmode=disable

# AI (provider: openai | deepseek | moonshot | qwen)
LLM_PROVIDER=openai
# Latest recommended defaults:
#   openai   -> gpt-5.3-chat-latest (or gpt-4o-mini for a cheaper fallback)
#   deepseek -> deepseek-v4-pro     (vision-capable; v4-flash is text-only)
#   moonshot -> kimi-k2.6           (latest multimodal flagship)
#   qwen     -> qwen3.5-plus        (native vision-language on DashScope)
LLM_MODEL=gpt-5.3-chat-latest
LLM_API_KEY=sk-...
# Optional custom endpoint, e.g. https://api.deepseek.com/ or https://api.moonshot.cn/v1
LLM_BASE_URL=

# S3 / S3-compatible storage (dev: MinIO, prod: AWS S3 or Cloudflare R2)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=still-uploads
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin

# CORS
CORS_ALLOWED_ORIGINS=*

# Auth (Clerk) — https://dashboard.clerk.com
CLERK_SECRET_KEY=sk_test_...

# Observability (Sentry) — optional
SENTRY_DSN=https://...@sentry.io/...

# OpenTelemetry — optional
OTEL_SERVICE_NAME=still-backend
OTEL_EXPORTER_OTLP_ENDPOINT=
